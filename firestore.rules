rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Customers collection
    match /customers/{customerId} {
      allow read, write: if request.auth.uid == customerId;
    }
    
    // Service Providers collection - allow all authenticated users to read
    match /service_providers/{spId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == spId;
    }
    
    // Slots collection - customers can read and service providers can create/update
    match /slots/{slotId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth.uid == request.resource.data.serviceProviderId || (request.auth != null && request.resource.data.isBooked == true && request.resource.data.customerId == request.auth.uid);
      allow delete: if request.auth.uid == request.resource.data.serviceProviderId;
    }
    
    // Reviews collection
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == request.resource.data.customerId;
      allow update, delete: if request.auth.uid == resource.data.customerId;
    }
    
    // Bookings collection
    match /bookings/{bookingId} {
      // Customers can read their own bookings
      allow read: if request.auth.uid == resource.data.customerId;
      // Service providers can read bookings for their services
      allow read: if request.auth.uid == resource.data.serviceProviderId;
      allow create: if request.auth.uid == request.resource.data.customerId;
      allow update: if request.auth.uid == resource.data.serviceProviderId || request.auth.uid == resource.data.customerId;
      allow delete: if request.auth.uid == resource.data.customerId;
    }
    
    // Service Offerings collection - SPs manage their own, customers can read
    match /service_offerings/{offeringId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == request.resource.data.serviceProviderId;
      allow update, delete: if request.auth.uid == resource.data.serviceProviderId;
    }

    // Payments collection - service providers can create and read their own payments
    match /payments/{paymentId} {
      allow read: if request.auth.uid == resource.data.serviceProviderId;
      allow create: if request.auth.uid == request.resource.data.serviceProviderId;
    }

    // Work Photos collection - SPs upload their own, all authenticated users can view
    match /work_photos/{photoId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == request.resource.data.serviceProviderId;
      allow delete: if request.auth.uid == resource.data.serviceProviderId;
    }
    
    // OTP Verification collection - allow read/write for email verification
    match /otpVerification/{email} {
      allow write: if request.auth == null;
      allow read: if request.auth == null || request.auth.uid != null;
      allow delete: if request.auth == null || request.auth.uid != null;
    }
    
    // Conversations collection - real-time chat
    match /conversations/{conversationId} {
      allow read, write: if request.auth.uid in resource.data.participants;
      allow create: if request.auth != null;
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow update: if request.auth.uid == resource.data.senderId;
      }
    }
  }
}
